# ── Techuncos environment variables ─────────────────────────────
# Copy to .env.local and fill in. Never commit real secrets.

# Public site URL (used for canonical URLs, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://techuncos.com

# ── Admin authentication ───────────────────────────────────────
# Session signing secret, min 32 chars. Generate: openssl rand -base64 48
AUTH_SECRET=
# Admin account (env-based store; move to a DB table for multiple users)
ADMIN_EMAIL=admin@techuncos.com
ADMIN_NAME=Techuncos Admin
ADMIN_ROLE=super_admin
# bcrypt hash of the admin password, base64-encoded.
# Generate: node scripts/hash-password.mjs "YourStrongPassword"
ADMIN_PASSWORD_HASH_B64=

# Supabase — powers the admin article editor and the live article data
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary (image storage — not required for the homepage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Google Search Console verification token (meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Telegram bot (auto-post on publish — Phase 4 backend)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_INFO=@techuncosinfo
TELEGRAM_CHANNEL_MAIN=@techuncos
